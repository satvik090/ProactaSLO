SERVICES=auth,payment,order,inventory,shipping,notification,user,cart,search,recommendation,review,warehouse,gateway,scheduler,audit
PROMETHEUS_URL=http://prometheus:9090
KAFKA_BROKER=kafka:9092
REDIS_URL=redis://redis:6379
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/proactaslo
SCRAPE_INTERVAL_SECONDS=15
RING_BUFFER_SIZE=120
PREDICTION_TTL_SECONDS=30
ALERT_THRESHOLD_DEFAULT=0.75
MODEL_DIR=./models
